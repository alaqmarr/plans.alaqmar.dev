generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id            String        @id @default(cuid())
  name          String
  description   String?
  price         Float
  discountPrice Float?        // Calculated effective price
  tenureYears   Int           @default(1)
  paymentTerms  String        @default("[{\"name\":\"Advance\",\"percent\":50},{\"name\":\"Mid-Stage\",\"percent\":25},{\"name\":\"Final Deployment\",\"percent\":25}]")
  validity      String?       // e.g., "1 year", "3 years"
  isPopular     Boolean       @default(false)
  features      PlanFeature[]
  clients       Client[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Feature {
  id            String        @id @default(cuid())
  name          String
  description   String?
  price         Float         @default(0)
  isOneTime     Boolean       @default(false)
  upgradedById  String?
  upgradedBy    Feature?      @relation("FeatureUpgrade", fields: [upgradedById], references: [id])
  upgradesFor   Feature[]     @relation("FeatureUpgrade")
  plans         PlanFeature[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PlanFeature {
  planId    String
  featureId String
  isIncluded Boolean @default(true) // Whether the feature is included or excluded
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
}

model CustomItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  isOneTime   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSettings {
  id                String   @id @default(cuid())
  contactEmail      String?
  whatsappNumber    String?
  upiId             String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  updatedAt         DateTime @updatedAt
}

model Client {
  id               String   @id @default(cuid())
  name             String
  email            String?
  phoneNumbers     String[]
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  invoices         Invoice[]
  tickets          Ticket[]
  offeredPrice     Float
  paymentStructure String   @default("[]") // JSON representing payment milestones
  trackingLink     String   @unique @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  milestoneName   String
  amount          Float
  fileUrl         String
  createdAt       DateTime @default(now())
}

model Ticket {
  id          String          @id @default(cuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject     String
  description String
  status      String          @default("open")
  priority    String          @default("normal")
  createdBy   String          @default("admin")
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    String
  message   String
  createdAt DateTime @default(now())
}
